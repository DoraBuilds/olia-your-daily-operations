# ─── Supabase (required) ──────────────────────────────────────────────────────
# Copy from: Supabase Dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.your_anon_key_here

# ─── Stripe (configure before enabling payments) ──────────────────────────────
# Public key (safe to commit): Stripe Dashboard → Developers → API keys
VITE_STRIPE_PUBLISHABLE_KEY=pk_live_...

# Stripe Price IDs — create products + prices in Stripe Dashboard first
# Enterprise is sales-led (no Stripe checkout) — no price ID needed
VITE_STRIPE_PRICE_STARTER_MONTHLY=price_...
VITE_STRIPE_PRICE_STARTER_ANNUAL=price_...
VITE_STRIPE_PRICE_GROWTH_MONTHLY=price_...
VITE_STRIPE_PRICE_GROWTH_ANNUAL=price_...

# Stripe Customer Portal URL — from: Stripe Dashboard → Billing → Customer portal → Copy link
VITE_STRIPE_CUSTOMER_PORTAL_URL=https://billing.stripe.com/p/login/...

# ─── Google Maps (optional — enables address autocomplete + mini map preview) ──
# Create a key at: https://console.cloud.google.com/google/maps-apis/credentials
# Enable these three APIs on the same key:
#   - Maps JavaScript API
#   - Places API
#   - Maps Static API
# Restrict the key to your domain in production (HTTP referrers).
VITE_GOOGLE_MAPS_API_KEY=

# ─── Server-side secrets ───────────────────────────────────────────────────────
# These MUST NOT be in .env.local — set them in:
#   Supabase Dashboard → Edge Functions → Manage secrets
#
#   ANTHROPIC_API_KEY       → AI checklist builder (generate-checklist function)
#   STRIPE_SECRET_KEY       → create-checkout-session + stripe-webhook functions
#   STRIPE_WEBHOOK_SECRET   → verify Stripe webhook signatures

# ─── Key rotation notes ───────────────────────────────────────────────────────
# VITE_SUPABASE_ANON_KEY:  This is a PUBLIC JWT, safe to ship in the client
#   bundle. Rotate via Supabase Dashboard → Project Settings → API → Reset keys
#   if it is ever exposed in a context where it should not be (e.g. committed
#   to a public repo). After rotating, update .env.local and redeploy.
#
# Dev / staging / prod:    Use a separate Supabase project per environment.
#   Dev: local `supabase start` or a personal project
#   Staging: a dedicated project for QA
#   Prod: production project (never run migrations against prod manually)
